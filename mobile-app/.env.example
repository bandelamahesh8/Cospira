# Cospira Mobile - Server configuration
# Copy to .env and set values. Expo exposes EXPO_PUBLIC_* at build time.

# Server host (no protocol). Examples:
# - 192.168.1.3    Physical device on same LAN as server
# - 10.0.2.2       Android Emulator (localhost)
# - localhost       iOS Simulator
EXPO_PUBLIC_SERVER_HOST=192.168.1.3

# Server port (optional, default 3001)
EXPO_PUBLIC_SERVER_PORT=3001
