    "dev": "concurrently --kill-others-on-fail -n \"client,server\" -c \"magenta,cyan\" \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "npm run dev --prefix server",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "prepare": "husky",
    "desktop": "tauri",
    "desktop:dev": "tauri dev --config desktop-shell/tauri.conf.json",
    "desktop:connect": "tauri dev --config desktop-shell/tauri.connect.conf.json",
    "desktop:build": "tauri build --config desktop-shell/tauri.conf.json"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "server/src/**/*.js": [
      "cd server && npm run lint -- --fix",
      "cd server && npm run format"
    ]
