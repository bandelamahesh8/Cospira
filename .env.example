# =============================================================================
# COSPIRA PRODUCTION ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# -----------------------------------------------------------------------------
# DOMAIN & NETWORKING
# -----------------------------------------------------------------------------
# Your production domain name (e.g., cospira.com or app.cospira.com)
DOMAIN_NAME=localhost

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/cospira

# -----------------------------------------------------------------------------
# SUPABASE
# -----------------------------------------------------------------------------
# Supabase project URL (found in your Supabase project settings)
SUPABASE_URL=https://ysessmuraxozobczjfbq.supabase.co

# Supabase service role key (found in your Supabase project API settings)
# WARNING: This is a secret key with admin privileges - keep it secure!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase anon/public key (for client-side usage)
VITE_SUPABASE_URL=https://ysessmuraxozobczjfbq.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_W3jlkc_LLiXmEAnUgKuBRA_1sNxZpg7

# -----------------------------------------------------------------------------
# AUTHENTICATION & SECURITY
# -----------------------------------------------------------------------------
# Secret key for JWT token signing (generate a random string)
# You can generate one with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# -----------------------------------------------------------------------------
# EXTERNAL SERVICES
# -----------------------------------------------------------------------------
# OpenAI API Key (for AI features)
OPENAI_API_KEY=sk-your-openai-api-key

# Deepgram API Key (for voice features)
DEEPGRAM_API_KEY=your-deepgram-api-key

# Google Gemini API Key (for AI features)
GEMINI_API_KEY=your-gemini-api-key

# -----------------------------------------------------------------------------
# EMAIL (Optional - for notifications)
# -----------------------------------------------------------------------------
# SMTP settings for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# -----------------------------------------------------------------------------
# REDIS (Optional - for production scaling)
# -----------------------------------------------------------------------------
# Redis connection URL (if using external Redis)
# REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
# Server port (default: 3001)
PORT=3001

# Node environment
NODE_ENV=production

# Client URL (your frontend URL)
CLIENT_URL=https://${DOMAIN_NAME}

# WebSocket URL (for client connection)
VITE_WS_URL=https://10.149.54.239:3001

# Use Redis for Socket.IO adapter (true/false)
USE_REDIS=true

# -----------------------------------------------------------------------------
# NGROK (Development Only)
# -----------------------------------------------------------------------------
# Ngrok auth token (for local development tunneling)
# NGROK_AUTHTOKEN=your-ngrok-token
