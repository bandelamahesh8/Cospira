{
  "name": "cospira-server",
  "version": "1.0.0",
  "description": "WebSocket server for Cospira real-time communication",
  "main": "src/index.js",
  "scripts": {
    "start": "concurrently \"node src/api/server.js\" \"node src/signaling/server.js\"",
    "dev:api": "nodemon src/api/server.js",
    "dev:signaling": "nodemon src/signaling/server.js",
    "dev": "nodemon src/index.js",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write \"src/**/*.js\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@deepgram/sdk": "^4.11.3",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@google/generative-ai": "^0.24.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "@supabase/supabase-js": "^2.86.0",
    "agora-access-token": "^2.0.4",
    "axios": "^1.6.0",
    "chess.js": "^1.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^7.1.0",
    "http-proxy": "^1.18.1",
    "jsonwebtoken": "^9.0.2",
    "mediasoup": "^3.19.12",
    "mongoose": "^9.0.2",
    "ms": "^2.1.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.12",
    "openai": "^6.16.0",
    "playwright": "^1.57.0",
    "playwright-extra": "^4.3.6",
    "prom-client": "^15.1.3",
    "puppeteer-core": "^24.37.2",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "redis": "^4.6.10",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.2",
    "socket.io-parser": "^4.2.5",
    "uuid": "^9.0.0",
    "winston": "^3.18.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.1.1"
  },
  "type": "module"
}
